          "react",
          "expo-status-bar",
          "expo-splash-screen",
          "expo-notifications",
          "@tanstack/react-query"
        ]
      },
      "exports": [
        "default RootLayout"
      ],
      "importedBy": []
    },
    {
      "path": "apps/mobile/app/index.tsx",
      "imports": {
        "internal": [
          "apps/mobile/src/stores/auth.store.ts"
        ],
