# ─── App ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
DOMAIN=yourdomain.com

# ─── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=connectify
POSTGRES_USER=connectify
POSTGRES_PASSWORD=change_me_strong_password

# ─── MongoDB ───────────────────────────────────────────
MONGO_USER=connectify
MONGO_PASSWORD=change_me_strong_password
MONGO_URI=mongodb://connectify:change_me_strong_password@mongo:27017/connectify?authSource=admin&replicaSet=rs0

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_64_char_random_secret_here_use_openssl_rand_base64_48
JWT_REFRESH_SECRET=change_me_different_64_char_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── OTP / MSG91 ───────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_otp_template_id

# ─── Razorpay ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=change_me_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=change_me_razorpay_webhook_secret

# ─── Agora ─────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ─── FCM (Firebase Cloud Messaging) ───────────────────
FCM_PROJECT_ID=your_firebase_project_id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nchange_me\n-----END PRIVATE KEY-----\n"

# ─── Docker registry ───────────────────────────────────
DOCKER_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

# ─── Next.js (web) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com
