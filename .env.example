# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# Database
DATABASE_URL=postgresql://connectify:connectify_dev@localhost:5432/connectify
MONGODB_URI=mongodb://localhost:27017/connectify?replicaSet=rs0
REDIS_URL=redis://localhost:6379

# JWT (must be at least 32 chars)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Agora
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# MSG91 (OTP)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Platform
PLATFORM_COMMISSION_RATE=0.15
MIN_WALLET_BALANCE_WARNING=30

# Feature Flags
FEATURE_KAFKA_ENABLED=false
FEATURE_AI_MODERATION_ENABLED=false
FEATURE_AUDIO_TRANSCRIPTION_ENABLED=false
